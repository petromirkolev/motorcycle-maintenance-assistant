{
  "name": "motocare",
  "version": "1.0.0",
  "description": "MotoCare is a small, real-life usable motorcycle maintenance reminder app.",
  "main": "index.js",
  "scripts": {
    "test:e2e": "node tests/scripts/reset-test-db.js && playwright test",
    "test:e2e:ui": "node tests/scripts/reset-test-db.js && playwright test --ui",
    "test:e2e:headed": "node tests/scripts/reset-test-db.js && playwright test --headed",
    "test:e2e:debug": "node tests/scripts/reset-test-db.js && playwright test --debug",
    "db:test:reset": "node tests/scripts/reset-test-db.js",
    "docker:test:up": "docker compose -f docker-compose.yml -f docker-compose.test.yml up --build -d",
    "docker:test:down": "docker compose -f docker-compose.yml -f docker-compose.test.yml down",
    "test:docker": "playwright test --config=playwright.docker.config.ts",
    "test:docker:fresh": "npm run db:test:reset && npm run docker:test:up && npm run test:docker"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/petromirkolev/motocare"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/petromirkolev/motocare/issues"
  },
  "homepage": "https://github.com/petromirkolev/motocare#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
