{
  "name": "motocare-maintenance-tracker",
  "version": "1.0.0",
  "description": "MotoCare Maintenance Tracker is a small, real-life usable motorcycle maintenance app.",
  "main": "index.js",
  "scripts": {
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "db:test:reset": "node tests/scripts/reset-test-db.js",
    "test:local": "npm run db:up && npm run db:test:reset && playwright test --config=playwright.local.config.ts",
    "test:local:ui": "npm run db:up && npm run db:test:reset && playwright test --config=playwright.local.config.ts --ui",
    "docker:test:up": "docker compose -f docker-compose.yml -f docker-compose.test.yml up --build -d",
    "docker:test:down": "docker compose -f docker-compose.yml -f docker-compose.test.yml down -v",
    "docker:test": "playwright test --config=playwright.docker.config.ts",
    "docker:test:ui": "playwright test --config=playwright.docker.config.ts --ui",
    "docker:test:fresh": "npm run docker:test:down && npm run docker:test:up && npm run db:test:reset && npm run test:docker",
    "test:prod": "playwright test --config=playwright.prod.config.ts",
    "test:prod:ui": "playwright test --config=playwright.prod.config.ts --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/petromirkolev/motocare-maintenance-tracker"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/petromirkolev/motocare-maintenance-tracker/issues"
  },
  "homepage": "https://github.com/petromirkolev/motocare-maintenance-tracker#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "dotenv": "^17.3.1",
    "pg": "^8.20.0",
    "typescript": "^5.9.3"
  }
}
